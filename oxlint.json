{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": ["apps/macos/**", "coverage/**", "dist/**", "node_modules/**", "references/**"],
  "plugins": ["typescript", "import", "unicorn", "oxc"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "warn"
  },
  "rules": {
    "no-console": "warn",
    "typescript/no-explicit-any": "error"
  }
}
