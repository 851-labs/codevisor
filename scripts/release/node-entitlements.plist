<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- V8 reserves executable memory when JavaScript starts. Without this,
	     the hardened-runtime production build can launch node version checks but
	     crashes as soon as the bundled server executes real JS. -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
</dict>
</plist>
