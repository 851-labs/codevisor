<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>SUAllowsAutomaticUpdates</key>
	<true/>
	<key>SUEnableAutomaticChecks</key>
	<true/>
	<key>SUEnableSystemProfiling</key>
	<false/>
	<key>SUFeedURL</key>
	<string>https://updates.codevisor.dev/appcast-arm64.xml</string>
	<key>SUPublicEDKey</key>
	<string>1FsNm9QTvUciP2sETZFfeTkWHCPjRNU6mEQ1wzqQz2k=</string>
	<!--
	  Codevisor servers speak plain HTTP: the local server on 127.0.0.1 and
	  remote machines over private networks (e.g. Tailscale, which encrypts
	  the transport itself). App Transport Security would otherwise reject
	  every remote machine connection with NSURLError -1022.
	-->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
	<key>NSScreenCaptureUsageDescription</key>
	<string>Codevisor uses window sharing to show which apps Computer Use can see and control.</string>
	<!-- Public event-ingestion configuration; this token cannot read PostHog data. -->
	<key>CodevisorPostHogProjectToken</key>
	<string>$(CODEVISOR_POSTHOG_PROJECT_TOKEN)</string>
	<key>CodevisorPostHogHost</key>
	<string>$(CODEVISOR_POSTHOG_HOST)</string>
	<!--
	  codevisor:// deeplinks (codevisor-dev:// in Debug so the dev app and
	  the installed production app never race for the same handler). Used by
	  `codevisor setup` on remote machines to hand the client a ready-made
	  add-machine link.
	-->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>$(CODEVISOR_URL_SCHEME)</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
