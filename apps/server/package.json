{
  "name": "@codevisor/server",
  "private": true,
  "type": "module",
  "bin": {
    "codevisor": "./dist/cli.js",
    "codevisor-server": "./dist/main.js",
    "codevisor-terminal-proxy": "./dist/terminal-proxy.js"
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "typecheck": "tsc -b tsconfig.json --pretty false",
    "test": "vitest run src --passWithNoTests",
    "test:coverage": "vitest run src --coverage",
    "dev": "tsc -b tsconfig.json && node dist/main.js serve",
    "start": "node dist/main.js serve"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.92",
    "@earendil-works/pi-ai": "0.80.9",
    "@codevisor/agent-runtime": "workspace:*",
    "@codevisor/api": "workspace:*",
    "@codevisor/db": "workspace:*",
    "@codevisor/terminal": "workspace:*",
    "@executor-js/runtime-quickjs": "1.5.32",
    "@modelcontextprotocol/sdk": "1.29.0",
    "effect": "4.0.0-beta.92",
    "proper-lockfile": "4.1.2",
    "ws": "8.18.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/proper-lockfile": "4.1.4",
    "@types/ws": "8.5.13",
    "vitest": "4.1.6"
  }
}
